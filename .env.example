# Supabase — proyecto en EU (Frankfurt).
# Copia este archivo a .env.local y rellena con tus valores reales.
# .env.local NUNCA se sube al repositorio (ver .gitignore).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Clave SECRETA (service_role). SOLO para scripts de servidor (p. ej. test:rls)
# y el cron de notificaciones. NUNCA con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...o-service_role-jwt

# Web Push (VAPID). Genera con: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...clave-publica
VAPID_PRIVATE_KEY=...clave-privada
VAPID_SUBJECT=mailto:soporte@terap.ia
# Secreto para autorizar el endpoint de cron de envío (/api/cron/notifications).
CRON_SECRET=cadena-aleatoria

