# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (las claves NUNCA al repo)
.env*
# ...excepto la plantilla de ejemplo (sin secretos)
!.env.example

# vercel
.vercel

# Capacitor: los proyectos nativos se generan con `cap add` en una máquina con
# las toolchains (Xcode / Android SDK). No se versionan en este repo.
/android
/ios

# typescript
*.tsbuildinfo
next-env.d.ts
